# ==========================================
# PRODUCTION ENVIRONMENT VARIABLES (BACKEND)
# Deploy to Render or Railway
# ==========================================

# Port for the Node.js server
PORT=10000

# The environment
NODE_ENV=production

# Supabase Credentials (from Supabase Dashboard > Settings > API)
SUPABASE_URL=https://<YOUR-PROJECT-ID>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<YOUR-SERVICE-ROLE-KEY>

# Resend Email API Key (for Invoices & Warning emails)
RESEND_API_KEY=re_...
FROM_EMAIL=billing@your-verified-domain.com
PLATFORM_ADMIN_EMAIL=you@quadem.agency

# Frontend Application URL (so backend emails link back correctly)
APP_URL=https://your-frontend-vercel-url.vercel.app

# Note: Paystack keys are securely stored in the `payment_gateways` database table,
# not in the .env file!


# ==========================================
# PRODUCTION ENVIRONMENT VARIABLES (FRONTEND)
# Deploy to Vercel
# ==========================================

# The external URL of your deployed Backend API
VITE_API_URL=https://your-render-backend-url.onrender.com/api

# Supabase Credentials (Public)
VITE_SUPABASE_URL=https://<YOUR-PROJECT-ID>.supabase.co
VITE_SUPABASE_ANON_KEY=<YOUR-ANON-KEY>
